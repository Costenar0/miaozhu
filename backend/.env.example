# ============================================================
# LLM 配置（必填，取消注释你使用的服务商，只保留一组）
# ============================================================

# --- OpenAI ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key
LLM_MODEL=gpt-4o                  # 推荐；可选：gpt-4o-mini（更快更便宜）

# --- DeepSeek ---
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=sk-your-api-key
# LLM_MODEL=deepseek-chat          # 推荐，中文和代码能力优秀，价格低

# --- 通义千问（阿里云） ---
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-api-key
# LLM_MODEL=qwen-plus              # 推荐；可选：qwen-turbo（更快）、qwen-max（更强）

# --- 智谱 GLM ---
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_API_KEY=your-api-key
# LLM_MODEL=glm-4-plus             # 推荐；可选：glm-4-flash（免费额度大）

# --- 月之暗面 Kimi ---
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_API_KEY=sk-your-api-key
# LLM_MODEL=moonshot-v1-8k         # 可选：moonshot-v1-32k（长上下文）

# --- 百度文心一言 ---
# LLM_BASE_URL=https://qianfan.baidubce.com/v2
# LLM_API_KEY=your-api-key
# LLM_MODEL=ernie-4.0-8k           # 可选：ernie-3.5-8k（更便宜）

# --- 本地部署 Ollama ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:14b            # 建议 14B 以上；可选：qwen2.5:32b、deepseek-v2:16b

# --- 硅基流动 SiliconFlow ---
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=sk-your-api-key
# LLM_MODEL=deepseek-ai/DeepSeek-V3

# ============================================================
# 可选配置
# ============================================================

# CORS 允许的前端域名（生产部署时改为实际域名）
# CORS_ORIGINS=["http://localhost:5173"]

# 调度器参数
# SCHEDULER_MAX_CONCURRENT_LLM=5       # 最大并发 LLM 调用数
# SCHEDULER_MAX_CONCURRENT_EXPORT=4    # 最大并发导出任务数
# SCHEDULER_POLL_INTERVAL=5            # 轮询间隔（秒）
